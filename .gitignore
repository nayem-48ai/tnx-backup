# Portable binaries auto-downloaded at runtime (do not commit)
bin/

# Runtime state
.initialized
logs/*.log
logs/history.json
reports/*.html
reports/*.csv

# rclone remote config now lives inside the project (holds MEGA credentials) - never commit it
config/rclone.conf
config/rclone.conf.*

# rclone config lives in user's rclone config dir, never here
*.conf.local
logs/*.log
logs/history.json
!logs/.gitkeep
reports/*.html
reports/*.csv
!reports/.gitkeep
